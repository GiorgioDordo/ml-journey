   "source": [
    "def string_encoder(string, shift):\n",
    "  encoded_string = \"\"\n",
    "  for char in string:\n",
    "    encoded_string = encoded_string + chr(ord(char) + shift)\n",
    "  return encoded_string\n",
    "\n",
    "string_encoder(\"hello!\", 3)\n",
    "\n",
    "\n"
   ]
  }
