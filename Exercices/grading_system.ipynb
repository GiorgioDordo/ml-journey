   "source": [
    "def scores(n):\n",
    "  if n == 0:\n",
    "    return \"F\"\n",
    "  elif n < 60:\n",
    "    return \"D\"\n",
    "  elif n < 70:\n",
    "    return \"C\"\n",
    "  elif n < 80:\n",
    "    return \"B\"\n",
    "  elif n <= 100:\n",
    "    return \"A\"\n",
    "  \n",
    "print(scores(32))\n",
    "\n",
    "#a simple grade calculator that takes a score and returns the corresponding letter grade."
   ]
  }
