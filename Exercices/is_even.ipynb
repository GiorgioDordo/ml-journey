   "source": [
    "def is_even(n):\n",
    "    return n % 2 == 0\n",
    "\n",
    "li = [2, 5, 20, 4, 7, 8, 9]\n",
    "\n",
    "res = filter(is_even, li)\n",
    "\n",
    "print(list(res))\n",
    "\n",
    "# a simple function that checks if a number is even and then uses the filter function to filter out even numbers from a list."
   ]
  }
